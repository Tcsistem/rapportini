    var ca=t.getAttribute('data-cancel-can'); if(ca){ closeEdit('can-'+ca); return; }
    var sv=t.getAttribute('data-save-can'); if(sv){ saveCanEdit(sv,t); return; }
    var rm=t.getAttribute('data-del-can'); if(rm){ delCan(rm,t); return; }
