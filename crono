  google.script.run
    .withSuccessHandler(function(){ btn.disabled=false; btn.style.opacity='1'; S.cantieri.forEach(function(c){ if(c.id===id){c.nome=payload.nome;c.commessa=payload.commessa;c.attivita=payload.attivita;c.mezzo=payload.mezzo;c.stato=payload.stato;} }); renderCan(); aggiornaFiltri(); renderGrid(); toast('Cantiere aggiornato'); })
    .withFailureHandler(function(err){ btn.disabled=false; btn.style.opacity='1'; toast('Errore: '+err.message); })
    .updateCantiere(payload);
}

document.getElementById('btn-save-can').onclick=function(){ saveCan(this); };
function saveCan(btn){
  var nome=document.getElementById('c-nome').value.trim(); if(!nome){ alert('Nome obbligatorio'); return; }
  btn.disabled=true; btn.style.opacity='.4';
  var payload={nome:nome,commessa:document.getElementById('c-comm').value.trim(),attivita:document.getElementById('c-att').value.trim(),mezzo:document.getElementById('c-mezzo').value,stato:document.getElementById('c-stato').value,note:document.getElementById('c-note').value.trim()};
  google.script.run
    .withSuccessHandler(function(res){ btn.disabled=false; btn.style.opacity='1'; payload.id=res.id; if(!payload.note) payload.note=''; S.cantieri.push(payload); ['c-nome','c-comm','c-att','c-note'].forEach(function(i){document.getElementById(i).value='';}); document.getElementById('c-mezzo').value=''; toggleForm('form-can'); renderCan(); aggiornaFiltri(); renderGrid(); toast('Cantiere aggiunto'); })
    .withFailureHandler(function(err){ btn.disabled=false; btn.style.opacity='1'; toast('Errore: '+err.message); })
    .addCantiere(payload);
}
function delCan(id,btn){
  if(!confirm('Rimuovere il cantiere?')) return; if(btn) btn.disabled=true;
  google.script.run
    .withSuccessHandler(function(){ S.cantieri=S.cantieri.filter(function(c){return c.id!==id;}); S.pianificazione=S.pianificazione.filter(function(p){return p.cantiereId!==id;}); renderCan(); aggiornaFiltri(); renderGrid(); toast('Cantiere rimosso'); })
    .withFailureHandler(function(err){ if(btn) btn.disabled=false; toast('Errore: '+err.message); })
