    .withSuccessHandler(function(res){ btn.disabled=false; btn.style.opacity='1'; S.mezzi.push({id:res.id,nome:nome,targa:targa,note:nota}); document.getElementById('m-nome').value=''; document.getElementById('m-targa').value=''; document.getElementById('m-note').value=''; toggleForm('form-mez'); renderMez(); aggiornaMezziSelect(); aggiornaFiltri(); toast('Mezzo aggiunto'); })
    .withFailureHandler(function(err){ btn.disabled=false; btn.style.opacity='1'; toast('Errore: '+err.message); })
    .addMezzo({nome:nome,targa:targa,note:nota});
}
function delMez(id,btn){
  if(!confirm('Rimuovere questo mezzo?')) return; if(btn) btn.disabled=true;
  google.script.run
    .withSuccessHandler(function(){ S.mezzi=S.mezzi.filter(function(m){return m.id!==id;}); renderMez(); aggiornaMezziSelect(); aggiornaFiltri(); toast('Mezzo rimosso'); })
    .withFailureHandler(function(err){ if(btn) btn.disabled=false; toast('Errore: '+err.message); })
    .deleteMezzo(id);
}

// ── VISTA DIPENDENTE ─────────────────────────────────────────────
function fillWorkerSel(){
  var sel=document.getElementById('w-sel'); var cur=sel.value;
  var html='<option value="">- Scegli -</option>';
  S.dipendenti.forEach(function(d){ html+='<option value="'+d.id+'">'+esc(d.nome)+'</option>'; });
  sel.innerHTML=html; if(cur) sel.value=cur;
}
document.getElementById('w-sel').onchange=function(){ loadWorker(); };
function loadWorker(){
  var id=document.getElementById('w-sel').value;
  if(!id){ document.getElementById('worker-view').innerHTML=''; return; }
  document.getElementById('w-label').textContent=fmtRange(workerMonday);
  setS('Caricamento...');
  google.script.run
    .withSuccessHandler(function(data){ renderWorker(data); setS('Connesso al foglio Google'); })
    .withFailureHandler(function(err){ toast('Errore: '+err.message); })
    .getWorkerWeek(id,workerMonday);
}
function workerPrev(){ workerMonday=addDays(workerMonday,-7); loadWorker(); }
function workerNext(){ workerMonday=addDays(workerMonday,7); loadWorker(); }
function renderWorker(data){
  document.getElementById('w-label').textContent=fmtRange(data.monday);
  var v=document.getElementById('worker-view');
  if(!data.dipendente){ v.innerHTML=''; return; }
  var d=data.dipendente;
  var lav=0; data.giorni.forEach(function(g){ if(g.cantieri.length) lav++; });
  var html='<div class="worker-hdr"><div class="worker-av">'+ini(d.nome)+'</div>'+
    '<div><div style="font-size:17px;font-weight:600">'+esc(d.nome)+'</div>'+
    '<div style="font-size:13px;color:#aaa;margin-top:2px">'+(d.ruolo||'')+(d.telefono?' - '+d.telefono:'')+'</div>'+
    '<div style="font-size:12px;color:#888;margin-top:4px">'+fmtRange(data.monday)+' - '+lav+' giorni lavorativi</div></div></div>';
  data.giorni.forEach(function(g,i){
    var dt=new Date(g.date); var isWe=i>=5; var isDom=i===6;
    html+='<div class="day-card"><div class="day-head" style="'+(isWe?'background:#fafaf9':'')+'">'+
      '<div class="wd" style="'+(isWe?'color:#aaa':'')+'">'+GIORNI[i]+'</div>'+
      '<div class="dt">'+dt.toLocaleDateString('it-IT',{day:'numeric',month:'long'})+'</div></div><div class="day-body">';
    if(!g.cantieri.length){ html+='<div class="day-off">'+(isDom?'Domenica - riposo':(isWe?'Sabato - riposo':'Nessun cantiere assegnato'))+'</div>'; }
    else {
      g.cantieri.forEach(function(c2){
        // Recupera la nota aggiornata dal cantiere locale
        var canLocale = null;
        for(var cx=0;cx<S.cantieri.length;cx++){ if(S.cantieri[cx].id===c2.cantiereId){ canLocale=S.cantieri[cx]; break; } }
        var notaC = (canLocale && canLocale.note) ? canLocale.note : (c2.note||'');
        html+='<div class="site-row"><div class="dot" style="background:'+siteColor(c2.cantiereId)+'"></div>'+
          '<div style="flex:1;min-width:0"><div class="sname">'+esc(c2.nomeCantiere)+'</div><div class="stags">'+
          (c2.attivita?'<span class="tag tag-a">'+esc(c2.attivita)+'</span>':'')+
          (c2.commessa?'<span class="tag tag-c">'+esc(c2.commessa)+'</span>':'')+
          (c2.mezzo?'<span class="tag tag-m">'+esc(c2.mezzo)+'</span>':'')+
          '</div>'+
          (notaC?'<div style="margin-top:5px;font-size:12px;color:#78350f;background:#fef3c7;border-radius:5px;padding:4px 8px;line-height:1.4">'+esc(notaC)+'</div>':'')+
          '</div></div>';
      });
    }
    html+='</div></div>';
  });
  v.innerHTML=html;
}

boot();
