  google.script.run
    .withSuccessHandler(function(){ btn.disabled=false; btn.style.opacity='1'; S.mezzi.forEach(function(m){ if(m.id===id){m.nome=payload.nome;m.targa=payload.targa;m.note=payload.note;} }); renderMez(); aggiornaMezziSelect(); aggiornaFiltri(); toast('Mezzo aggiornato'); })
    .withFailureHandler(function(err){ btn.disabled=false; btn.style.opacity='1'; toast('Errore: '+err.message); })
    .updateMezzo(payload);
}

document.getElementById('btn-save-mez').onclick=function(){ saveMez(this); };
function saveMez(btn){
  var nome=document.getElementById('m-nome').value.trim();
  var targa=document.getElementById('m-targa').value.trim().toUpperCase();
  if(!nome||!targa){ alert('Nome e targa sono obbligatori'); return; }
