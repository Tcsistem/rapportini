function saveCanEdit(id,btn){
  var p=document.getElementById('can-'+id);
  var nome=p.querySelector('.ec-nome').value.trim(); if(!nome){ alert('Nome obbligatorio'); return; }
  btn.disabled=true; btn.style.opacity='.4';
