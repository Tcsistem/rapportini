<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Cronoprogramma</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:#f0f0ef;color:#1a1a18;font-size:14px}
.hdr{background:#1a1a18;color:#fff;padding:.75rem 1.5rem;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:10}
.hdr-title{font-size:16px;font-weight:500}
.hdr-sub{font-size:11px;color:#aaa;margin-top:1px}
.tabs{background:#fff;border-bottom:1px solid #e0e0de;display:flex;padding:0 1.5rem;overflow-x:auto}
.tab{padding:11px 18px;background:none;border:none;border-bottom:2px solid transparent;cursor:pointer;font-size:13px;color:#888;font-family:inherit;white-space:nowrap}
.tab.on{color:#1a1a18;border-bottom:2px solid #1a1a18;font-weight:500}
.btn{padding:7px 14px;border-radius:7px;font-size:12px;cursor:pointer;font-family:inherit;border:none}
.btn-w{background:#fff;color:#1a1a18;border:1px solid #ddd}.btn-w:hover{background:#f5f5f4}
.btn-d{background:#1a1a18;color:#fff}.btn-d:hover{background:#333}
.btn-r{background:none;color:#dc2626;border:none;font-size:12px;cursor:pointer;padding:3px 6px}
.btn-e{background:none;color:#2563eb;border:none;font-size:12px;cursor:pointer;padding:3px 6px}
.btn-sm{padding:5px 12px;font-size:12px}
.btn-warn{background:#f59e0b;color:#fff;border:none}.btn-warn:hover{background:#d97706}
.btn:disabled{opacity:.4;cursor:default}
.page{padding:1.25rem 1.5rem;max-width:100%;margin:0 auto}
.narrow{max-width:820px;margin:0 auto;padding:1.25rem 1.5rem}
.row{display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem;gap:8px;flex-wrap:wrap}
.spinner{width:22px;height:22px;border:2px solid #e0e0de;border-top:2px solid #1a1a18;border-radius:50%;animation:spin .8s linear infinite;margin:4rem auto}
@keyframes spin{to{transform:rotate(360deg)}}
.empty{text-align:center;padding:3rem;color:#aaa;font-size:13px}
.week-nav{display:flex;align-items:center;gap:6px;background:#fff;border:1px solid #e0e0de;border-radius:8px;padding:4px 8px}
.week-nav span{font-size:13px;font-weight:500;min-width:150px;text-align:center}
.week-nav button{background:none;border:none;cursor:pointer;font-size:18px;color:#555;padding:1px 6px;border-radius:5px;line-height:1}
.week-nav button:hover{background:#f0f0ef}

/* FILTRI */
.fg-filter{display:flex;flex-direction:column;gap:3px}
.fg-filter label{font-size:10px;color:#aaa;font-weight:500;text-transform:uppercase;letter-spacing:.04em}
.fg-filter select{padding:5px 10px;border:1px solid #e0e0de;border-radius:7px;font-size:12px;font-family:inherit;background:#fff;color:#1a1a18;cursor:pointer;min-width:140px}
.fg-filter select:focus{outline:none;border-color:#1a1a18}

/* AVVISO COMPLETEZZA */
.alert-box{background:#fef3c7;border:1px solid #f59e0b;border-radius:10px;padding:.85rem 1.1rem;margin-bottom:1rem;display:none}
.alert-box.show{display:block}
.alert-title{font-weight:500;font-size:13px;color:#92400e;margin-bottom:6px}
.alert-list{font-size:12px;color:#78350f;line-height:1.9}

/* GRIGLIA */
.grid-wrap{overflow-x:auto;margin-top:.5rem}
.grid{border-collapse:collapse;width:100%;min-width:860px}
.grid th{background:#1a1a18;color:#fff;padding:9px 10px;font-weight:500;font-size:12px;text-align:left;border:1px solid #2a2a28;white-space:nowrap}
.grid th.day{text-align:center;min-width:150px}
.grid td{border:1px solid #e0e0de;vertical-align:top;background:#fff}
.grid td.info{background:#fafaf9;padding:8px 10px;min-width:110px;max-width:150px}
.grid td.day-cell{padding:6px;min-width:150px}
.can-name{font-weight:500;font-size:13px;margin-bottom:3px}
.tag{display:inline-block;font-size:10px;padding:2px 6px;border-radius:4px;font-weight:500;margin:1px 1px 0 0}
.tag-c{background:#e0e7ff;color:#3730a3}
.tag-m{background:#fef3c7;color:#92400e}
.tag-a{background:#f0fdf4;color:#166534}
.tag-p{background:#fef9c3;color:#713f12}
.tag-x{background:#fee2e2;color:#991b1b}

/* CHIP */
.chip{display:flex;align-items:center;gap:5px;background:#f0f0ef;border-radius:6px;padding:4px 7px;margin-bottom:3px;font-size:12px}
.chip-av{width:22px;height:22px;border-radius:50%;background:#dbeafe;color:#1e40af;font-weight:700;font-size:9px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.chip-name{flex:1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;font-weight:500}
.chip-rm{background:none;border:none;color:#bbb;cursor:pointer;font-size:15px;line-height:1;padding:0 2px;flex-shrink:0}
.chip-rm:hover{color:#dc2626}
.cell-sel{width:100%;font-size:11px;padding:4px;border:1px dashed #ccc;border-radius:6px;background:#fff;color:#888;cursor:pointer;margin-top:3px;font-family:inherit}
.cell-sel:focus{outline:none;border-color:#1a1a18;color:#1a1a18}
.cell-sel.loading{opacity:.5;pointer-events:none}
.cell-input{width:100%;font-size:11px;padding:4px 6px;border:1px solid #e0e0de;border-radius:6px;background:#fff;color:#1a1a18;margin-top:3px;font-family:inherit}
.cell-input:focus{outline:none;border-color:#1a1a18}
.grid-mezzo,.grid-can{margin-top:3px;font-size:11px;padding:4px;border:1px solid #e0e0de;border-radius:6px;background:#fff;color:#1a1a18;width:100%}
.grid-mezzo:focus,.grid-can:focus{outline:none;border-color:#1a1a18}
.print-only{display:none}
.cell-copy-row{display:flex;gap:3px;margin-top:3px}
.day-copy-btn{background:none;border:1px solid #ccc;color:#aaa;border-radius:4px;padding:2px 6px;font-size:10px;cursor:pointer;flex:1}
.day-copy-btn:hover{background:#f5f5f4;color:#555;border-color:#888}
.day-paste-btn{background:#16a34a;border:none;color:#fff;border-radius:4px;padding:2px 6px;font-size:10px;cursor:pointer;flex:1}
.day-paste-btn:hover{background:#15803d}
.cell-note{width:100%;font-size:10px;padding:3px 5px;border:1px solid #e0e0de;border-radius:5px;background:#fffbf0;color:#78350f;resize:none;font-family:inherit;margin-top:3px}
.cell-note:focus{outline:none;border-color:#f59e0b}
.hide-empty-btn.active{background:#1a1a18;color:#fff;border-color:#1a1a18}

/* FORM */
.form-panel{background:#f5f5f4;border:1px solid #e0e0de;border-radius:10px;padding:1rem;margin-bottom:1rem}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:10px}
.form-row3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;margin-bottom:10px}
.fg{display:flex;flex-direction:column;gap:4px}
.fg label{font-size:11px;color:#666;font-weight:500}
input,select{padding:8px 10px;border:1px solid #ddd;border-radius:8px;font-size:13px;width:100%;font-family:inherit;background:#fff;color:#1a1a18}
input:focus,select:focus{outline:none;border-color:#1a1a18}

/* LIST CARD con pannello modifica */
.list-card{background:#fff;border:1px solid #e0e0de;border-radius:10px;margin-bottom:7px;overflow:hidden}
.list-card-main{padding:.85rem 1.1rem;display:flex;align-items:center;gap:12px}
.list-av{width:38px;height:38px;border-radius:50%;background:#dbeafe;color:#1e40af;font-weight:700;font-size:13px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.list-av.c{background:#fef3c7;color:#92400e;border-radius:9px;font-size:10px;text-align:center;line-height:1.2;padding:2px}
.list-av.m{background:#fce7f3;color:#9d174d;border-radius:9px;font-size:18px;display:flex;align-items:center;justify-content:center}
.edit-panel{display:none;padding:.85rem 1.1rem;border-top:1px solid #f0f0ef;background:#fafaf9}
.edit-panel.open{display:block}

/* VISTA DIPENDENTE */
.worker-hdr{background:#1a1a18;color:#fff;border-radius:12px;padding:1.25rem 1.5rem;margin-bottom:1rem;display:flex;align-items:center;gap:14px}
.worker-av{width:50px;height:50px;border-radius:50%;background:#3b82f6;color:#fff;font-size:17px;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.day-card{background:#fff;border:1px solid #e0e0de;border-radius:11px;margin-bottom:9px;overflow:hidden}
.day-head{padding:.7rem 1.1rem;display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid #f0f0ef}
.day-head .wd{font-weight:500}
.day-head .dt{font-size:12px;color:#888}
.day-body{padding:.7rem 1.1rem}
.site-row{display:flex;gap:10px;align-items:flex-start;padding:.45rem 0;border-bottom:1px solid #f5f5f4}
.site-row:last-child{border:none}
.dot{width:9px;height:9px;border-radius:50%;flex-shrink:0;margin-top:4px}
.sname{font-weight:500;font-size:13px}
.stags{display:flex;gap:4px;flex-wrap:wrap;margin-top:3px}
.day-off{font-size:13px;color:#bbb;padding:.2rem 0}

.toast{position:fixed;bottom:1.5rem;right:1.5rem;background:#1a1a18;color:#fff;padding:9px 15px;border-radius:8px;font-size:13px;opacity:0;transition:opacity .2s;pointer-events:none;z-index:999}
.toast.show{opacity:1}
@media(max-width:600px){.form-row,.form-row3{grid-template-columns:1fr}}
@media print{
  @page{size:A4 landscape;margin:8mm}
  *{-webkit-print-color-adjust:exact;print-color-adjust:exact}
  body{background:#fff;font-size:9px}
  .hdr,.tabs,.no-print,.cell-sel,.alert-box{display:none!important}
  .page{padding:0;max-width:100%}
  #mc,#v-piano{display:block!important}
  #v-dip,#v-can,#v-mez,#v-worker{display:none!important}
  .grid-wrap{overflow:visible}
  .grid{width:100%;font-size:8.5px;table-layout:fixed}
  .grid th{padding:5px 4px;font-size:8px}
  .grid th.day{min-width:0}
  .grid td.info{padding:4px 5px;min-width:0;max-width:none;word-break:break-word}
  .grid td.day-cell{padding:3px}
  .tag{font-size:7px;padding:1px 4px}
  .chip{padding:2px 4px;margin-bottom:2px;font-size:8px;gap:3px}
  .chip-av{width:16px;height:16px;font-size:7px}
  .chip-rm{display:none}
  .grid-mezzo,.grid-can,.grid-comm,.cell-input{display:none!important}
  .print-only{display:inline!important}
  #print-title{display:block!important;font-size:13px;font-weight:600;margin-bottom:6px}
}
</style>
</head>
<body>

<div class="hdr">
  <div>
    <div class="hdr-title">Cronoprogramma</div>
    <div class="hdr-sub" id="ss">Caricamento...</div>
  </div>
  <div class="no-print">
    <button onclick="window.print()" class="btn btn-w btn-sm">&#128424; Stampa</button>
  </div>
</div>

<div class="tabs no-print">
  <button id="t-piano"  class="tab on"  onclick="go('piano')">&#128197; Pianificazione</button>
  <button id="t-dip"    class="tab"     onclick="go('dip')">&#128374; Dipendenti</button>
  <button id="t-can"    class="tab"     onclick="go('can')">&#127959; Cantieri</button>
  <button id="t-mez"    class="tab"     onclick="go('mez')">&#128656; Mezzi</button>
  <button id="t-worker" class="tab"     onclick="go('worker')">&#128100; Vista dipendente</button>
</div>

<div id="lv" style="margin:4rem auto;max-width:80px"><div class="spinner"></div></div>
<div id="ev" style="display:none;text-align:center;padding:3rem">
  <p style="color:#dc2626;margin-bottom:1rem" id="em">Errore</p>
  <button onclick="boot()" class="btn btn-w">Riprova</button>
</div>

<div id="mc" style="display:none">

  <!-- PIANIFICAZIONE -->
  <div id="v-piano" class="page">
    <div id="print-title" style="display:none"></div>
    <div class="row no-print">
      <div style="display:flex;gap:12px;align-items:flex-end;flex-wrap:wrap">
        <div class="week-nav">
          <button onclick="prevWeek()">&#8592;</button>
          <span id="week-label">-</span>
          <button onclick="nextWeek()">&#8594;</button>
        </div>
        <div class="fg-filter">
          <label>Cantiere</label>
          <select id="f-cantiere" onchange="renderGrid()"><option value="">Tutti</option></select>
        </div>
        <div class="fg-filter">
          <label>Mezzo</label>
          <select id="f-mezzo" onchange="renderGrid()"><option value="">Tutti</option></select>
        </div>
      </div>
      <div style="display:flex;gap:8px;flex-wrap:wrap">
        <button onclick="checkCompletezza()" class="btn btn-warn btn-sm">! Controlla copertura</button>
        <button onclick="inviaNotificheSett(this)" class="btn btn-w btn-sm" style="border-color:#16a34a;color:#16a34a">&#9993; Invia notifiche settimana</button>
        <button id="btn-hide-empty" onclick="toggleHideEmpty()" class="btn btn-w btn-sm hide-empty-btn">Nascondi vuoti</button>
        <button onclick="copyPrevWeek()" class="btn btn-w btn-sm">↩ Copia settimana prec.</button>
      </div>
    </div>
    <div class="alert-box no-print" id="alert-box">
      <div class="alert-title">! Operai non assegnati questa settimana</div>
      <div class="alert-list" id="alert-list"></div>
    </div>
    <div class="grid-wrap">
      <table class="grid"><thead id="gh"></thead><tbody id="gb"></tbody></table>
    </div>
  </div>

  <!-- DIPENDENTI -->
  <div id="v-dip" style="display:none">
    <div class="narrow">
      <div class="row">
        <span style="color:#888;font-size:13px" id="n-dip"></span>
        <button onclick="toggleForm('form-dip')" class="btn btn-d">+ Aggiungi dipendente</button>
      </div>
      <div id="form-dip" style="display:none" class="form-panel">
        <div class="form-row">
          <div class="fg"><label>Nome e cognome *</label><input id="d-nome" placeholder="Mario Rossi"></div>
          <div class="fg"><label>Ruolo</label>
            <select id="d-ruolo"><option value="">Seleziona</option><option>Capo cantiere</option><option>Muratore</option><option>Carpentiere</option><option>Elettricista</option><option>Idraulico</option><option>Gruista</option><option>Geometra</option><option>Operaio generico</option><option>Altro</option></select>
          </div>
        </div>
        <div class="form-row">
          <div class="fg"><label>Telefono</label><input id="d-tel" type="tel" placeholder="+39 333 0000000"></div>
          <div class="fg"><label>Email <span style="font-size:10px;color:#3b82f6;font-weight:400">● notifiche</span></label><input id="d-email" type="email" placeholder="mario@email.com"></div>
        </div>
        <div style="display:flex;gap:8px;justify-content:flex-end">
          <button onclick="toggleForm('form-dip')" class="btn btn-w">Annulla</button>
          <button id="btn-save-dip" class="btn btn-d">Salva</button>
        </div>
      </div>
      <div id="list-dip"></div>
    </div>
  </div>

  <!-- CANTIERI -->
  <div id="v-can" style="display:none">
    <div class="narrow">
      <div class="row">
        <span style="color:#888;font-size:13px" id="n-can"></span>
        <button onclick="toggleForm('form-can')" class="btn btn-d">+ Aggiungi cantiere</button>
      </div>
      <div id="form-can" style="display:none" class="form-panel">
        <div class="form-row">
          <div class="fg"><label>Nome cantiere *</label><input id="c-nome" placeholder="CHEMI"></div>
          <div class="fg"><label>N commessa</label><input id="c-comm" placeholder="00247CEN25"></div>
        </div>
        <div class="form-row">
          <div class="fg"><label>Attività</label><input id="c-att" placeholder="Lavori elettrici"></div>
          <div class="fg"><label>Mezzo</label><select id="c-mezzo"><option value="">- Nessun mezzo -</option></select></div>
        </div>
        <div class="form-row">
          <div class="fg"><label>Stato</label>
            <select id="c-stato"><option value="attivo">Attivo</option><option value="in_pausa">In pausa</option><option value="completato">Completato</option></select>
          </div>
          <div class="fg"><label>Note per i dipendenti</label><input id="c-note" placeholder="Istruzioni, indicazioni..."></div>
        </div>
        <div style="display:flex;gap:8px;justify-content:flex-end">
          <button onclick="toggleForm('form-can')" class="btn btn-w">Annulla</button>
          <button id="btn-save-can" class="btn btn-d">Salva</button>
        </div>
      </div>
      <div id="list-can"></div>
    </div>
  </div>

  <!-- MEZZI -->
  <div id="v-mez" style="display:none">
    <div class="narrow">
      <div class="row">
        <span style="color:#888;font-size:13px" id="n-mez"></span>
        <button onclick="toggleForm('form-mez')" class="btn btn-d">+ Aggiungi mezzo</button>
      </div>
      <div id="form-mez" style="display:none" class="form-panel">
        <div class="form-row">
          <div class="fg"><label>Nome mezzo *</label><input id="m-nome" placeholder="Furgone, Autocarro..."></div>
          <div class="fg"><label>Targa *</label><input id="m-targa" placeholder="GV198RL"></div>
        </div>
        <div class="fg" style="margin-bottom:10px"><label>Note</label><input id="m-note" placeholder="es. Toyota Hilux bianco"></div>
        <div style="display:flex;gap:8px;justify-content:flex-end">
          <button onclick="toggleForm('form-mez')" class="btn btn-w">Annulla</button>
          <button id="btn-save-mez" class="btn btn-d">Salva</button>
        </div>
      </div>
      <div id="list-mez"></div>
    </div>
  </div>

  <!-- VISTA DIPENDENTE -->
  <div id="v-worker" style="display:none">
    <div class="narrow">
      <div class="row no-print">
        <div class="fg" style="flex:1;max-width:280px">
          <label style="font-size:12px;color:#666;font-weight:500">Dipendente</label>
          <select id="w-sel"><option value="">- Scegli -</option></select>
        </div>
        <div class="week-nav">
          <button onclick="workerPrev()">&#8592;</button>
          <span id="w-label">-</span>
          <button onclick="workerNext()">&#8594;</button>
        </div>
      </div>
      <div id="worker-view"></div>
    </div>
  </div>

</div>
<div class="toast" id="toast"></div>

<script>
var S = { dipendenti:[], mezzi:[], cantieri:[], pianificazione:[], monday:'', weekDates:[] };
var currentMonday = '';
var workerMonday  = '';
var GIORNI       = ['Lunedì','Martedì','Mercoledì','Giovedì','Venerdì','Sabato','Domenica'];
var GIORNI_SHORT = ['Lun','Mar','Mer','Gio','Ven','Sab','Dom'];
var COLORS       = ['#3b82f6','#10b981','#f59e0b','#ef4444','#8b5cf6','#ec4899','#06b6d4','#84cc16'];
var colorMap     = {};

function ini(n){ return (n||'?').split(' ').map(function(p){return p[0]||'';}).join('').toUpperCase().slice(0,2); }
function setS(t){ document.getElementById('ss').textContent=t; }
function toggleForm(id){ var e=document.getElementById(id); e.style.display=e.style.display==='none'?'block':'none'; }
function toast(msg){ var t=document.getElementById('toast'); t.textContent=msg; t.classList.add('show'); setTimeout(function(){t.classList.remove('show');},2500); }
function addDays(s,n){ var d=new Date(s); d.setDate(d.getDate()+n); return d.toISOString().slice(0,10); }
function fmtRange(mon){
  var dom=addDays(mon,6);
  return new Date(mon).toLocaleDateString('it-IT',{day:'numeric',month:'short'})+' - '+new Date(dom).toLocaleDateString('it-IT',{day:'numeric',month:'short'});
}
function siteColor(id){ if(!colorMap[id]){ colorMap[id]=COLORS[Object.keys(colorMap).length%COLORS.length]; } return colorMap[id]; }
function esc(s){ return (s||'').replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;'); }

function go(t){
  ['piano','dip','can','mez','worker'].forEach(function(x){
    document.getElementById('t-'+x).classList.toggle('on',x===t);
    document.getElementById('v-'+x).style.display=x===t?'block':'none';
  });
  if(t==='worker') fillWorkerSel();
  if(t==='can') aggiornaMezziSelect();
}

// ── BOOT ────────────────────────────────────────────────────────
function boot(){
  document.getElementById('lv').style.display='block';
  document.getElementById('ev').style.display='none';
  document.getElementById('mc').style.display='none';
  setS('Caricamento...');
  google.script.run
    .withSuccessHandler(function(data){
      try {
        // Normalizza dati: garantisce che tutti i campi array esistano
        S = {
          dipendenti:    Array.isArray(data.dipendenti)    ? data.dipendenti    : [],
          mezzi:         Array.isArray(data.mezzi)         ? data.mezzi         : [],
          cantieri:      Array.isArray(data.cantieri)      ? data.cantieri      : [],
          pianificazione:Array.isArray(data.pianificazione)? data.pianificazione: [],
          monday:        data.monday    || '',
          weekDates:     Array.isArray(data.weekDates)     ? data.weekDates     : []
        };
        currentMonday = S.monday;
        if(!workerMonday) workerMonday = S.monday;
        document.getElementById('lv').style.display='none';
        document.getElementById('mc').style.display='block';
        renderAll();
        setS('Connesso al foglio Google');
      } catch(jsErr) {
        document.getElementById('lv').style.display='none';
        document.getElementById('ev').style.display='block';
        document.getElementById('em').textContent='Errore JS: '+jsErr.message;
        console.error('renderAll error:', jsErr);
      }
    })
    .withFailureHandler(function(err){
      document.getElementById('lv').style.display='none';
      document.getElementById('ev').style.display='block';
      document.getElementById('em').textContent='Errore server: '+(err.message||JSON.stringify(err));
      console.error('boot server error:', err);
    })
    .getAllData(null);
}

function refreshWeekOnly(){
  google.script.run
    .withSuccessHandler(function(data){ S.pianificazione=data.pianificazione; S.weekDates=data.weekDates; renderGrid(); setS('Connesso'); })
    .withFailureHandler(function(err){ toast('Errore: '+err.message); })
    .getAllData(currentMonday);
}
function prevWeek(){
  setS('Caricamento...');
  google.script.run
    .withSuccessHandler(function(data){ S=data; currentMonday=data.monday; renderAll(); setS('Connesso al foglio Google'); })
    .withFailureHandler(function(err){ toast('Errore: '+err.message); })
    .getAllData(addDays(currentMonday,-7));
}
function nextWeek(){
  setS('Caricamento...');
  google.script.run
    .withSuccessHandler(function(data){ S=data; currentMonday=data.monday; renderAll(); setS('Connesso al foglio Google'); })
    .withFailureHandler(function(err){ toast('Errore: '+err.message); })
    .getAllData(addDays(currentMonday,7));
}
function renderAll(){ aggiornaMezziSelect(); aggiornaFiltri(); renderGrid(); renderDip(); renderCan(); renderMez(); }

// ── SELECT MEZZI nei form ────────────────────────────────────────
function aggiornaMezziSelect(){
  var opts='<option value="">- Nessun mezzo -</option>';
  for(var i=0;i<S.mezzi.length;i++){
    var m=S.mezzi[i];
    opts+='<option value="'+esc(m.targa)+'">'+esc(m.targa)+(m.nome?' - '+esc(m.nome):'')+'</option>';
  }
  var sel=document.getElementById('c-mezzo');
  if(sel){ var cur=sel.value; sel.innerHTML=opts; if(cur) sel.value=cur; }
}

// ── FILTRI pianificazione ────────────────────────────────────────
function aggiornaFiltri(){
  var fc=document.getElementById('f-cantiere');
  var fm=document.getElementById('f-mezzo');
  var curC=fc.value, curM=fm.value;
  fc.innerHTML='<option value="">Tutti</option>';
  fm.innerHTML='<option value="">Tutti</option>';
  var mezziVisti={};
  S.cantieri.forEach(function(c){
    if(c.stato==='completato') return;
    fc.innerHTML+='<option value="'+esc(c.id)+'">'+esc(c.nome)+'</option>';
    if(c.mezzo && !mezziVisti[c.mezzo]){
      fm.innerHTML+='<option value="'+esc(c.mezzo)+'">'+esc(c.mezzo)+'</option>';
      mezziVisti[c.mezzo]=true;
    }
  });
  if(curC) fc.value=curC;
  if(curM) fm.value=curM;
}

// ── CONTROLLO COMPLETEZZA ────────────────────────────────────────
function checkCompletezza(){
  var box=document.getElementById('alert-box');
  var lst=document.getElementById('alert-list');
  var dates=S.weekDates||[];
  var giorniLav=dates.slice(0,5); // solo lun-ven
  var problemi=[];
  giorniLav.forEach(function(date,i){
    var nonAss=[];
    S.dipendenti.forEach(function(d){
      var ha=S.pianificazione.some(function(p){ return p.dipendenteId===d.id && p.data===date; });
      if(!ha) nonAss.push(d.nome);
    });
    if(nonAss.length) problemi.push('<b>'+GIORNI[i]+' '+new Date(date).toLocaleDateString('it-IT',{day:'numeric',month:'short'})+'</b>: '+nonAss.join(', '));
  });
  if(!problemi.length){ toast('OK - Tutti gli operai sono assegnati'); box.classList.remove('show'); }
  else { lst.innerHTML=problemi.join('<br>'); box.classList.add('show'); }
}

// ── GRIGLIA ─────────────────────────────────────────────────────
var hideEmpty   = false;
var clipCell    = null; // { key, cid, date, assignments: [{dipendenteId,cantiereId,nomeDipendente,nomeCantiere}] }

function toggleHideEmpty(){
  hideEmpty = !hideEmpty;
  var btn = document.getElementById('btn-hide-empty');
  if(btn) btn.classList.toggle('active', hideEmpty);
  renderGrid();
}

function renderGrid(){
  var label=fmtRange(currentMonday);
  document.getElementById('week-label').textContent=label;
  document.getElementById('print-title').textContent='Cronoprogramma - '+label;
  var dates=S.weekDates||[];
  var filtCan=document.getElementById('f-cantiere').value;
  var filtMez=document.getElementById('f-mezzo').value;

  // Intestazione giorni con pulsanti copia/incolla
  var th='<tr><th>Cantiere</th><th>Attivita</th><th>Mezzo</th><th>Commessa</th><th>Note</th>';
  for(var i=0;i<dates.length;i++){
    var dt=new Date(dates[i]);
    th+='<th class="day">'+GIORNI_SHORT[i]+
      '<br><span style="font-weight:400;font-size:11px">'+dt.toLocaleDateString('it-IT',{day:'2-digit',month:'2-digit'})+'</span>'+

      '</th>';
  }
  document.getElementById('gh').innerHTML=th+'</tr>';

  var attivi=S.cantieri.filter(function(c){
    if(c.stato==='completato') return false;
    if(filtCan && c.id!==filtCan) return false;
    if(filtMez && c.mezzo!==filtMez) return false;
    return true;
  });

  if(!attivi.length){
    document.getElementById('gb').innerHTML='<tr><td colspan="'+(5+dates.length)+'" class="empty">Nessun cantiere corrispondente ai filtri.</td></tr>';
    document.getElementById('gb').onclick=null; document.getElementById('gb').onchange=null;
    return;
  }

  // Opzioni cantieri e mezzi per i select
  var canSelBase='';
  for(var k=0;k<S.cantieri.length;k++){
    var ck=S.cantieri[k];
    if(ck.stato!=='completato') canSelBase+='<option value="'+esc(ck.id)+'">'+esc(ck.nome)+'</option>';
  }
  var mezSelBase='<option value="">- Nessuno -</option>';
  for(var mi=0;mi<S.mezzi.length;mi++){
    var mz=S.mezzi[mi];
    mezSelBase+='<option value="'+esc(mz.targa)+'">'+esc(mz.targa)+(mz.nome?' ('+esc(mz.nome)+')':'')+'</option>';
  }

  var rows='';
  for(var ci=0;ci<attivi.length;ci++){
    var c=attivi[ci];

    // Conta assegnazioni totali per questo cantiere nella settimana
    var totAss=0;
    for(var pi=0;pi<S.pianificazione.length;pi++){
      if(S.pianificazione[pi].cantiereId===c.id) totAss++;
    }
    // Nascondi se richiesto e nessuna assegnazione
    if(hideEmpty && totAss===0) continue;

    // CANTIERE select
    var canSelHtml='<select class="cell-sel grid-can no-print" data-canid="'+c.id+'">';
    for(var k2=0;k2<S.cantieri.length;k2++){
      var ck2=S.cantieri[k2];
      if(ck2.stato!=='completato') canSelHtml+='<option value="'+ck2.id+'"'+(ck2.id===c.id?' selected':'')+'>'+esc(ck2.nome)+'</option>';
    }
    canSelHtml+='</select>';

    // MEZZO select
    var mezSelHtml='<select class="cell-sel grid-mezzo no-print" data-canid="'+c.id+'">';
    for(var mi2=0;mi2<S.mezzi.length;mi2++){
      var mz2=S.mezzi[mi2];
      mezSelHtml+='<option value="'+esc(mz2.targa)+'"'+(mz2.targa===c.mezzo?' selected':'')+'>'+esc(mz2.targa)+(mz2.nome?' ('+esc(mz2.nome)+')':'')+'</option>';
    }
    mezSelHtml+='</select>';

    // NOTE textarea inline
    var noteHtml='<textarea class="cell-note no-print" data-note-canid="'+c.id+'" rows="2" placeholder="Note per i dipendenti...">'+esc(c.note||'')+'</textarea>';
    var notePrint=c.note?'<span style="font-size:10px;color:#78350f">'+esc(c.note)+'</span>':'';

    var mezzoBadge=c.mezzo?'<span class="tag tag-m print-only">'+esc(c.mezzo)+'</span>':'';
    var commessaBadge=c.commessa?'<span class="tag tag-c">'+esc(c.commessa)+'</span>':'<span style="color:#ccc;font-size:12px">-</span>';

    var row=
      '<td class="info"><div class="can-name print-only">'+esc(c.nome)+'</div>'+canSelHtml+(c.stato==='in_pausa'?'<span class="tag tag-p">In pausa</span>':'')+
      '</td>'+
      '<td class="info"><span style="font-size:12px;color:#555">'+(c.attivita||'-')+'</span></td>'+
      '<td class="info">'+mezzoBadge+mezSelHtml+'</td>'+
      '<td class="info">'+commessaBadge+'</td>'+
      '<td class="info" style="min-width:130px">'+notePrint+noteHtml+'</td>';

    for(var di=0;di<dates.length;di++){
      var date=dates[di]; var cid=c.id;
      var assigned=[], occupatiOggi={};
      for(var px=0;px<S.pianificazione.length;px++){
        var p=S.pianificazione[px];
        if(p.data===date) occupatiOggi[p.dipendenteId]=true;
        if(p.cantiereId===cid && p.data===date) assigned.push(p);
      }
      var chips='';
      for(var ai=0;ai<assigned.length;ai++){
        var a=assigned[ai];
        chips+='<div class="chip"><div class="chip-av">'+ini(a.nomeDipendente)+'</div>'+
          '<span class="chip-name">'+esc(a.nomeDipendente)+'</span>'+
          '<button class="chip-rm" data-pid="'+a.id+'">x</button></div>';
      }
      var dipOpts='<option value="">+ aggiungi...</option>';
      var hasOpt=false;
      for(var si=0;si<S.dipendenti.length;si++){
        var dip=S.dipendenti[si];
        if(!occupatiOggi[dip.id]){ dipOpts+='<option value="'+dip.id+'|'+cid+'|'+date+'">'+esc(dip.nome)+'</option>'; hasOpt=true; }
      }
      chips+='<select class="cell-sel no-print"'+(hasOpt?'':' disabled title="Tutti assegnati"')+'>'+dipOpts+'</select>';
      // Pulsanti copia/incolla per cella singola
      var cellKey = cid+'|'+date;
      var isCopiata = clipCell && clipCell.key===cellKey;
      var puoIncollare = clipCell && clipCell.cid===cid && clipCell.date!==date;
      var cellBtns='<div class="cell-copy-row no-print">';
      if(assigned.length>0){
        cellBtns+='<button class="day-copy-btn" data-cell-copy="'+cellKey+'">'+(isCopiata?'Copiata':'Copia')+'</button>';
      }
      if(puoIncollare){
        cellBtns+='<button class="day-paste-btn" data-cell-paste="'+cid+'|'+date+'">Incolla</button>';
      }
      cellBtns+='</div>';
      row+='<td class="day-cell">'+chips+cellBtns+'</td>';
    }
    rows+='<tr>'+row+'</tr>';
  }
  document.getElementById('gb').innerHTML = rows || '<tr><td colspan="'+(5+dates.length)+'" class="empty">Tutti i cantieri sono nascosti (nessuna assegnazione).</td></tr>';

  var gb = document.getElementById('gb');

  // Click handler
  gb.onclick=function(e){
    var t=e.target;
    if(t.className==='chip-rm'){ removeP(t.getAttribute('data-pid')); return; }
    // Copia cella singola
    var copyCell=t.getAttribute('data-cell-copy');
    if(!copyCell && t.parentNode) copyCell=t.parentNode.getAttribute('data-cell-copy');
    if(copyCell){ copiaCella(copyCell); return; }
    // Incolla cella singola
    var pasteCell=t.getAttribute('data-cell-paste');
    if(!pasteCell && t.parentNode) pasteCell=t.parentNode.getAttribute('data-cell-paste');
    if(pasteCell){ var pp=pasteCell.split('|'); incollaCella(pp[0],pp[1]); return; }
  };

  // Change handler
  gb.onchange=function(e){
    var sel=e.target;
    if(!sel.classList) return;
    if(sel.classList.contains('grid-can')){
      var vecchioId=sel.getAttribute('data-canid');
      var nuovoId=sel.value;
      if(!nuovoId || nuovoId===vecchioId) return;
      var selects=document.querySelectorAll('.grid-can');
      for(var gi=0;gi<selects.length;gi++){
        if(selects[gi]!==sel && selects[gi].value===nuovoId){ toast('ATTENZIONE: Cantiere gia in un altra riga'); sel.value=vecchioId; return; }
      }
      sel.setAttribute('data-canid',nuovoId);
      var tr=sel.closest('tr');
      if(tr) tr.querySelectorAll('[data-canid]').forEach(function(el){ el.setAttribute('data-canid',nuovoId); });
      toast('Cantiere aggiornato');
      return;
    }
    if(sel.classList.contains('grid-mezzo')){
      var cid2=sel.getAttribute('data-canid');
      var nuovoMezzo=sel.value;
      var can2=null;
      for(var i=0;i<S.cantieri.length;i++){ if(S.cantieri[i].id===cid2){ can2=S.cantieri[i]; break; } }
      if(!can2) return;
      var altriMezzo=document.querySelectorAll('.grid-mezzo');
      for(var gm=0;gm<altriMezzo.length;gm++){
        if(altriMezzo[gm]!==sel && altriMezzo[gm].value===nuovoMezzo && nuovoMezzo!==''){
          toast('ATTENZIONE: Mezzo gia assegnato altrove'); sel.value=can2.mezzo; return;
        }
      }
      sel.disabled=true; setS('Salvataggio mezzo...');
      var p2={id:can2.id,nome:can2.nome,commessa:can2.commessa,attivita:can2.attivita,mezzo:nuovoMezzo,stato:can2.stato,note:can2.note||''};
      google.script.run
        .withSuccessHandler(function(res2){
          sel.disabled=false;
          if(res2 && !res2.success){ toast('! '+res2.error); sel.value=can2.mezzo; return; }
          can2.mezzo=nuovoMezzo; aggiornaFiltri(); setS('Connesso al foglio Google'); toast('Mezzo aggiornato');
        })
        .withFailureHandler(function(err){ sel.disabled=false; toast('Errore: '+err.message); })
        .updateCantiere(p2);
      return;
    }
    if(sel.classList.contains('cell-sel')){
      var val=sel.value; if(!val) return;
      var parts=val.split('|'); if(parts.length!==3) return;
      sel.disabled=true; sel.className='cell-sel loading'; setS('Salvataggio...');
      google.script.run
        .withSuccessHandler(function(res){
          if(!res.success){ toast(res.error||'Errore'); sel.disabled=false; sel.className='cell-sel'; sel.value=''; return; }
          refreshWeekOnly(); toast('Operaio aggiunto');
        })
        .withFailureHandler(function(err){ toast('Errore: '+err.message); sel.disabled=false; sel.className='cell-sel'; sel.value=''; })
        .addPianificazione({ dipendenteId:parts[0], cantiereId:parts[1], data:parts[2] });
      return;
    }
  };

  // Blur: salva note quando si esce dalla textarea
  gb.addEventListener('change', function(e){
    var ta=e.target;
    if(!ta.classList || !ta.classList.contains('cell-note')) return;
    var cid3=ta.getAttribute('data-note-canid');
    var nuovaNota=ta.value.trim();
    var can3=null;
    for(var i=0;i<S.cantieri.length;i++){ if(S.cantieri[i].id===cid3){ can3=S.cantieri[i]; break; } }
    if(!can3 || can3.note===nuovaNota) return;
    ta.style.borderColor='#f59e0b';
    var p3={id:can3.id,nome:can3.nome,commessa:can3.commessa,attivita:can3.attivita,mezzo:can3.mezzo,stato:can3.stato,note:nuovaNota};
    google.script.run
      .withSuccessHandler(function(){
        can3.note=nuovaNota; ta.style.borderColor=''; setS('Connesso al foglio Google'); toast('Nota salvata');
      })
      .withFailureHandler(function(err){ ta.style.borderColor='#dc2626'; toast('Errore: '+err.message); })
      .updateCantiere(p3);
  });
}

// ── COPIA / INCOLLA CELLA ────────────────────────────────────────
function copiaCella(cellKey){
  // cellKey = "cantiereId|data"
  var parts = cellKey.split('|');
  var cid   = parts[0];
  var date  = parts[1];
  var ass   = S.pianificazione.filter(function(p){ return p.cantiereId===cid && p.data===date; });
  if(!ass.length){ toast('Nessun operaio in questa cella'); return; }
  clipCell = { key:cellKey, cid:cid, date:date, assignments:ass };
  renderGrid();
  toast('Cella copiata ('+ass.length+' operai) - clicca Incolla nelle altre celle dello stesso cantiere');
}

function incollaCella(toCid, toDate){
  if(!clipCell){ toast('Prima copia una cella'); return; }
  setS('Incolla in corso...');
  google.script.run
    .withSuccessHandler(function(res){
      if(!res.success){ toast(res.error||'Errore'); return; }
      refreshWeekOnly();
      toast('Incollati '+res.added+' operai');
    })
    .withFailureHandler(function(err){ toast('Errore: '+err.message); })
    .copyDay(clipCell.date, [toDate]);
}


function removeP(id){
  if(!confirm('Rimuovere questo dipendente dalla giornata?')) return;
  google.script.run
    .withSuccessHandler(function(){ refreshWeekOnly(); toast('Rimosso'); })
    .withFailureHandler(function(err){ toast('Errore: '+err.message); })
    .removePianificazione(id);
}
function inviaNotificheSett(btn){
  if(!confirm('Inviare le notifiche a tutti gli operai assegnati questa settimana?')) return;
  btn.disabled=true; btn.style.opacity='.4';
  setS('Invio notifiche...');
  google.script.run
    .withSuccessHandler(function(res){
      btn.disabled=false; btn.style.opacity='1';
      setS('Connesso al foglio Google');
      toast('Notifiche inviate a '+res.count+' operai');
    })
    .withFailureHandler(function(err){ btn.disabled=false; btn.style.opacity='1'; toast('Errore: '+err.message); })
    .inviaNotificheSettimana(currentMonday);
}

function copyPrevWeek(){
  var prev=addDays(currentMonday,-7);
  if(!confirm('Copiare la settimana del '+fmtRange(prev)+' su questa?')) return;
  google.script.run
    .withSuccessHandler(function(res){ if(!res.success){ toast(res.error||'Nessun dato'); return; } refreshWeekOnly(); toast('Copiati '+res.added+' record'); })
    .withFailureHandler(function(err){ toast('Errore: '+err.message); })
    .copyWeek(addDays(currentMonday,-7),currentMonday);
}

// ── UTILITY FORM MODIFICA ────────────────────────────────────────
function toggleEdit(id){ var p=document.getElementById(id); if(!p) return; var was=p.classList.contains('open'); document.querySelectorAll('.edit-panel.open').forEach(function(el){el.classList.remove('open');}); if(!was) p.classList.add('open'); }
function closeEdit(id){ var p=document.getElementById(id); if(p) p.classList.remove('open'); }
function ruoloOpts(sel){ return ['','Capo cantiere','Muratore','Carpentiere','Elettricista','Idraulico','Gruista','Geometra','Operaio generico','Altro'].map(function(o){ return '<option'+(o===sel?' selected':'')+' value="'+o+'">'+(o||'Seleziona')+'</option>'; }).join(''); }
function mezziOpts(selTarga){ var h='<option value="">- Nessun mezzo -</option>'; S.mezzi.forEach(function(m){ h+='<option value="'+esc(m.targa)+'"'+(m.targa===selTarga?' selected':'')+'>'+esc(m.targa)+(m.nome?' - '+esc(m.nome):'')+'</option>'; }); return h; }

// ── DIPENDENTI ───────────────────────────────────────────────────
function renderDip(){
  var l=document.getElementById('list-dip');
  document.getElementById('n-dip').textContent=S.dipendenti.length+' dipendenti';
  if(!S.dipendenti.length){ l.innerHTML='<div class="empty">Nessun dipendente.</div>'; return; }
  var html='';
  S.dipendenti.forEach(function(d){
    html+=
      '<div class="list-card">'+
        '<div class="list-card-main">'+
          '<div class="list-av">'+ini(d.nome)+'</div>'+
          '<div style="flex:1;min-width:0">'+
            '<div style="font-weight:500">'+esc(d.nome)+'</div>'+
            '<div style="font-size:12px;color:#888">'+(d.ruolo||'')+(d.telefono?' - '+d.telefono:'')+'</div>'+
            '<div style="font-size:11px;color:'+(d.email?'#3b82f6':'#ccc')+'">'+(d.email?''+d.email:'nessuna email')+'</div>'+
          '</div>'+
          '<button class="btn-e" data-edit-dip="'+d.id+'">Modifica</button>'+
          '<button class="btn-r" data-del-dip="'+d.id+'">Rimuovi</button>'+
        '</div>'+
        '<div class="edit-panel" id="dep-'+d.id+'">'+
          '<div class="form-row"><div class="fg"><label>Nome *</label><input class="ed-nome" value="'+esc(d.nome)+'"></div>'+
          '<div class="fg"><label>Ruolo</label><select class="ed-ruolo">'+ruoloOpts(d.ruolo)+'</select></div></div>'+
          '<div class="form-row"><div class="fg"><label>Telefono</label><input class="ed-tel" value="'+esc(d.telefono||'')+'"></div>'+
          '<div class="fg"><label>Email</label><input class="ed-email" type="email" value="'+esc(d.email||'')+'"></div></div>'+
          '<div style="display:flex;gap:8px;justify-content:flex-end">'+
            '<button class="btn btn-w btn-sm" data-cancel-dip="'+d.id+'">Annulla</button>'+
            '<button class="btn btn-d btn-sm" data-save-dip="'+d.id+'">Salva</button>'+
          '</div></div></div>';
  });
  l.innerHTML=html;
  l.onclick=function(e){
    var t=e.target;
    var ed=t.getAttribute('data-edit-dip'); if(ed){ toggleEdit('dep-'+ed); return; }
    var ca=t.getAttribute('data-cancel-dip'); if(ca){ closeEdit('dep-'+ca); return; }
    var sv=t.getAttribute('data-save-dip'); if(sv){ saveDipEdit(sv,t); return; }
    var rm=t.getAttribute('data-del-dip'); if(rm){ delDip(rm,t); return; }
  };
}

function saveDipEdit(id,btn){
  var p=document.getElementById('dep-'+id);
  var nome=p.querySelector('.ed-nome').value.trim(); if(!nome){ alert('Nome obbligatorio'); return; }
  btn.disabled=true; btn.style.opacity='.4';
  var payload={id:id,nome:nome,ruolo:p.querySelector('.ed-ruolo').value,telefono:p.querySelector('.ed-tel').value.trim(),email:p.querySelector('.ed-email').value.trim()};
  google.script.run
    .withSuccessHandler(function(){ btn.disabled=false; btn.style.opacity='1'; S.dipendenti.forEach(function(d){ if(d.id===id){d.nome=payload.nome;d.ruolo=payload.ruolo;d.telefono=payload.telefono;d.email=payload.email;} }); renderDip(); toast('Aggiornato'); })
    .withFailureHandler(function(err){ btn.disabled=false; btn.style.opacity='1'; toast('Errore: '+err.message); })
    .updateDipendente(payload.id, payload.nome, payload.ruolo, payload.telefono, payload.email);
}

document.getElementById('btn-save-dip').onclick=function(){ saveDip(this); };
function saveDip(btn){
  var nome=document.getElementById('d-nome').value.trim(); if(!nome){ alert('Nome obbligatorio'); return; }
  btn.disabled=true; btn.style.opacity='.4';
  var ruolo=document.getElementById('d-ruolo').value, tel=document.getElementById('d-tel').value.trim(), email=document.getElementById('d-email').value.trim();
  google.script.run
    .withSuccessHandler(function(res){ btn.disabled=false; btn.style.opacity='1'; S.dipendenti.push({id:res.id,nome:nome,ruolo:ruolo,telefono:tel,email:email}); document.getElementById('d-nome').value=''; document.getElementById('d-tel').value=''; document.getElementById('d-email').value=''; document.getElementById('d-ruolo').value=''; toggleForm('form-dip'); renderDip(); renderGrid(); toast('Dipendente aggiunto'); })
    .withFailureHandler(function(err){ btn.disabled=false; btn.style.opacity='1'; toast('Errore: '+err.message); })
    .addDipendente({nome:nome,ruolo:ruolo,telefono:tel,email:email});
}
function delDip(id,btn){
